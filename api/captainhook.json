{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                  "regex": "/^\\[API|front|chore\\]/",
                  "error": "Commit message must start with [API]"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\PHP\\Action\\Linting"
            },
            {
                "action": "make format"
            },
            {
                "action": "make lint"
            },
            {
                "action": "make cardList",
                "conditions": [
                    {
                        "exec": "\\CaptainHook\\App\\Hook\\Condition\\FileStaged\\OfType",
                        "args": ["php"]
                    },
                    {
                        "exec": "CaptainHook.FileStaged.InDirectory",
                        "args": ["src/Game/Card"]
                    }
                ]
            }
        ]
    },
    "config": {
        "git-directory": "../.git"
    }
}
