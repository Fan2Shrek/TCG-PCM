{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                  "regex": "/^\\[API\\]/",
                  "error": "Commit message must start with [API]"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\PHP\\Action\\Linting"
            },
            {
                "action": "make format"
            },
            {
                "action": "make lint"
            }
        ]
    },
    "config": {
        "git-directory": "../.git"
    }
}
